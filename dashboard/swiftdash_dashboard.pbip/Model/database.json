            "dataType": "double"
          },
          {
            "name": "discount",
            "dataType": "double"
          },
          {
            "name": "tax",
            "dataType": "double"
          },
          {
            "name": "platform_fee",
            "dataType": "double"
          },
          {
            "name": "surge_multiplier",
            "dataType": "double"
          },
          {
            "name": "total_amount",
            "dataType": "double"
          },
          {
            "name": "payment_method",
            "dataType": "string"
          },
          {
            "name": "order_status",
            "dataType": "string"
          },
          {
            "name": "customer_city",
            "dataType": "string"
          },
          {
            "name": "restaurant_city",
            "dataType": "string"
          },
          {
            "name": "customer_rating",
            "dataType": "double"
          }
        ],
        "measures": [
          {
            "name": "Total Revenue",
            "expression": "CALCULATE(SUM(orders[total_amount]), orders[order_status] = \"Delivered\")"
          },
          {
            "name": "Total Orders",
            "expression": "CALCULATE(COUNTROWS(orders), orders[order_status] = \"Delivered\")"
          },
          {
            "name": "Avg Order Value",
            "expression": "DIVIDE([Total Revenue], [Total Orders])"
          },
          {
            "name": "Cancellation Rate",
            "expression": "VAR AllOrders = COUNTROWS(orders) VAR Cancelled = CALCULATE(COUNTROWS(orders), orders[order_status] = \"Cancelled\") RETURN DIVIDE(Cancelled, AllOrders, 0)"
          },
          {
            "name": "Avg Customer Rating",
            "expression": "CALCULATE(AVERAGE(orders[customer_rating]), orders[customer_rating] > 0)"
          },
          {
            "name": "Total Discounts Given",
            "expression": "SUM(orders[discount])"
          },
          {
            "name": "Unique Customers",
            "expression": "DISTINCTCOUNT(orders[customer_id])"
          },
          {
            "name": "Revenue MoM Growth",
            "expression": "VAR CurrentMonth = [Total Revenue] VAR PrevMonth = CALCULATE([Total Revenue], PREVIOUSMONTH('Calendar'[Date])) RETURN DIVIDE(CurrentMonth - PrevMonth, PrevMonth, 0)"
          },
          {
            "name": "Revenue YoY Growth",
            "expression": "VAR CurrentPeriod = [Total Revenue] VAR PrevPeriod = CALCULATE([Total Revenue], SAMEPERIODLASTYEAR('Calendar'[Date])) RETURN DIVIDE(CurrentPeriod - PrevPeriod, PrevPeriod, 0)"
          },
          {
            "name": "Revenue Rolling30D",
            "expression": "CALCULATE([Total Revenue], DATESINPERIOD('Calendar'[Date], MAX('Calendar'[Date]), -30, DAY))"
          },
          {
            "name": "Revenue MTD",
            "expression": "TOTALMTD([Total Revenue], 'Calendar'[Date])"
          },
          {
            "name": "Revenue QTD",
            "expression": "TOTALQTD([Total Revenue], 'Calendar'[Date])"
          },
          {
            "name": "Revenue YTD",
            "expression": "TOTALYTD([Total Revenue], 'Calendar'[Date])"
          },
          {
            "name": "Repeat Customer Rate",
            "expression": "VAR CustomersWithOrders = SUMMARIZE(orders, orders[customer_id])\nVAR RepeatCustomers = FILTER(CustomersWithOrders, CALCULATE(COUNTROWS(orders), orders[order_status] = \"Delivered\") > 1)\nRETURN DIVIDE(COUNTROWS(RepeatCustomers), COUNTROWS(CustomersWithOrders), 0)"
          },
          {
            "name": "Peak Hour Orders",
            "expression": "MAXX(VALUES(orders[order_hour]),\n    CALCULATE(COUNTROWS(orders), orders[order_status] = \"Delivered\"))"
          },
          {
            "name": "Orders Per Driver",
            "expression": "DIVIDE([Total Delivered Orders], [Active Drivers], 0)"
          },
          {
            "name": "Surge Revenue Premium",
            "expression": "SUM(orders[total_amount]) - SUMX(orders, orders[total_amount] / orders[surge_multiplier])"
          }
        ],
