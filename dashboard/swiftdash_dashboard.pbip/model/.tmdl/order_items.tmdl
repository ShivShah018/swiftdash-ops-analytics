table order_items {
    column order_item_id dataType: int64 { isKey: true }
    column order_id dataType: string
    column item_name dataType: string
    column category dataType: string
    column quantity dataType: int64
    column unit_price dataType: double
    column line_total dataType: double

    partition 'Partition' mode: import { source: #"order_items" }

}