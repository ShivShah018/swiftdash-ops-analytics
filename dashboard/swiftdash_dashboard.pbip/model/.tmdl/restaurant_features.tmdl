table restaurant_features {
    column restaurant_id dataType: string { isKey: true }
    column name dataType: string
    column cuisine_type dataType: string
    column city dataType: string
    column latitude dataType: double
    column longitude dataType: double
    column rating dataType: double
    column avg_cost_for_two dataType: int64
    column join_date dataType: string
    column is_active dataType: boolean { trueValue: "True", falseValue: "False" }
    column preparation_time_mins dataType: int64
    column total_orders dataType: double
    column total_revenue dataType: double
    column avg_order_value dataType: double
    column total_discount dataType: double
    column unique_customers dataType: double
    column avg_items_per_order dataType: double
    column cancellation_rate dataType: double
    column revenue_per_customer dataType: double
    column revenue_tier dataType: string

    partition 'Partition' mode: import { source: #"restaurant_features" }

}